# Copy to .env and fill in your values.

# Absolute path on the HOST to the directory with your video files.
# Mounted as /media inside the containers.
MEDIA_DIR=/path/to/your/media

# Where processed (browser-ready) HLS output is written, on the host's real disk.
# Kept on a host bind-mount (not a Docker volume) so big files aren't capped by
# the Docker VM disk image.
PROCESSED_DIR=/path/to/your/processed

# Used when running the Go app locally (without Docker). In Docker Compose this
# is set via the environment: block in docker-compose.yml.
DATABASE_URL=postgres://wp:wp@localhost:5432/watchparty?sslmode=disable

# Set to "false" to require login (no anonymous fallback). Leave unset/true only
# for local development before you've created an account.
DEV_AUTO_LOGIN=false
